PORT=5402
NODE_ENV=production
JWT_SECRET=change_me_in_production
DB_HOST=127.0.0.1
# 与 vino-mysql 同机并存时，宿主机映射端口一般为 3308（见服务器 docker ps）
DB_PORT=3308
DB_NAME=xykitchen_db
DB_USER=root
DB_PASSWORD=change_me
EMAIL_ENABLED=false
SMS_ENABLED=false
# 腾讯云 COS（勿将真实密钥提交到 git；仅在服务器 backend/.env 中填写）
COS_SECRET_ID=
COS_SECRET_KEY=
# 未配置 COS 时上传会落到本机 public/uploads；小程序加载图片需绝对地址时请设置，例如 http://106.54.50.88:5402
PUBLIC_BASE_URL=
