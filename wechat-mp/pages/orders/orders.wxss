.page {
  min-height: 100vh;
  background: #fdf5e6;
  padding: 24rpx;
  box-sizing: border-box;
}

.empty {
  text-align: center;
  color: #888;
  padding: 80rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #e8dcc8;
}

.row {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  padding: 8rpx 0;
  gap: 16rpx;
}

.muted {
  color: #888;
  flex-shrink: 0;
}

.price {
  color: #a32626;
  font-weight: 700;
}
