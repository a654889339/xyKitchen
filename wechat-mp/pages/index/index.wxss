.page { background: transparent; min-height: 100vh; position: relative; }

.home-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 78vh;
  min-height: 800rpx;
  z-index: 0;
  background: transparent;
}
.home-bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  object-position: center;
}

.hero { height: 55vw; max-height: 640rpx; min-height: 400rpx; background: transparent; position: relative; z-index: 1; }
.hero-overlay { position: absolute; left: 0; right: 0; top: 0; bottom: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.12) 0%, transparent 50%, rgba(255,255,255,0.05) 100%); }
.hero-header { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 30rpx; }
.hero-logo { height: 56rpx; width: auto; max-width: 200rpx; }
.hero-logo-text { color: #fff; font-size: 36rpx; font-weight: 700; letter-spacing: 4rpx; }
.hero-actions { display: flex; align-items: center; gap: 16rpx; }
.lang-switcher { display: flex; align-items: center; gap: 4rpx; padding: 8rpx 16rpx; border-radius: 32rpx; background: rgba(255,255,255,0.15); }
.lang-label { font-size: 24rpx; font-weight: 600; color: rgba(255,255,255,0.9); }
.lang-arrow { font-size: 20rpx; color: rgba(255,255,255,0.7); }

.home-bg-swiper { position: absolute; top: 0; left: 0; right: 0; bottom: 0; height: 100%; }
.home-bg-swiper swiper-item { height: 100%; }
.home-bg-swiper .home-bg-image { position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: block; }

/* 开场动画层 */
.splash-screen {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.splash-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  max-width: 640rpx;
  width: 100%;
  padding: 0 48rpx;
  box-sizing: border-box;
}
.splash-logo-img {
  max-width: 360rpx;
  max-height: 240rpx;
  opacity: 0;
  animation: splashCharIn 0.6s 0.3s ease forwards;
}
.splash-desc {
  font-size: 30rpx;
  text-align: center;
  letter-spacing: 2rpx;
  line-height: 1.5;
  max-width: 560rpx;
  min-height: 48rpx;
  opacity: 0;
  animation: splashCharIn 0.5s 0.8s ease forwards;
}
.splash-progress {
  width: 240rpx;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
  opacity: 0;
  animation: splashFadeIn 0.3s 1.2s ease forwards;
}
.splash-progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #B91C1C, #EF4444);
  border-radius: 4rpx;
  animation: splashProgressFill 1.8s 1.2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  width: 0;
}

@keyframes splashCharIn {
  to { opacity: 1; transform: translateY(0); }
}
@keyframes splashFadeIn {
  to { opacity: 1; }
}
@keyframes splashProgressFill {
  to { width: 100%; }
}
