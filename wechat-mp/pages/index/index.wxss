.page-root {
  min-height: 100vh;
  background: #fdf5e6;
}

.frame {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
  background-color: #fdf5e6;
  background-size: cover;
  background-position: center;
  border: 12rpx solid #a32626;
  border-radius: 8rpx;
}

.frame-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx 80rpx;
  min-height: 80vh;
}

.ribbon {
  background: #a32626;
  color: #fff;
  font-size: 28rpx;
  padding: 12rpx 48rpx;
  border-radius: 8rpx;
  margin-bottom: 48rpx;
  letter-spacing: 4rpx;
}

.shop-title {
  color: #a32626;
  font-size: 44rpx;
  font-weight: 800;
  margin-bottom: 80rpx;
  text-align: center;
  letter-spacing: 2rpx;
}

.actions {
  width: 100%;
  max-width: 560rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.btn-red {
  background: #a32626 !important;
  color: #fff !important;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 999rpx;
  padding: 20rpx 0;
  border: none;
}

.btn-second {
  opacity: 0.95;
}

.loading-tip {
  position: fixed;
  bottom: 40rpx;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 24rpx;
  color: #888;
}
