.wrap {
  min-height: 100vh;
  background: #fdf5e6;
  padding: 32rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 40rpx;
  font-weight: 800;
  color: #a32626;
  text-align: center;
  margin-bottom: 24rpx;
}

.body-scroll {
  flex: 1;
  max-height: 68vh;
  border: 2rpx solid #d4a59a;
  border-radius: 12rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.5);
}

.body-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  white-space: pre-wrap;
}

.btn-next {
  margin-top: 32rpx;
  background: #a32626;
  color: #fff;
  border-radius: 999rpx;
  font-size: 32rpx;
}
